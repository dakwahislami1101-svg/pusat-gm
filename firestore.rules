rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /settings/{documentId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email in [
        "eccko.w9@gmail.com",
        "dakwahislami1101@gmail.com",
        "swirbowl@gmail.com",
        "kedaikita1101@gmail.com",
        "tobutobu1101@gmail.com",
        "ekowahyudichannel@gmail.com",
        "eccko.w4@gmail.com",
        "satemaduracakmat1101@gmail.com",
        "dapurcici1101@gmail.com",
        "satesurabaya1101@gmail.com",
        "eccko.w10@gmail.com",
        "eccko.w3@gmail.com",
        "ecckoku1101@gmail.com",
        "proseshidup1101@gmail.com"
      ];
    }
  }
}
